# Web/API 监听地址。Docker 部署一般保持 0.0.0.0，表示容器内监听所有网卡。
HOST=0.0.0.0

# Web/API 端口。默认 5160，对外访问地址通常是 http://服务器IP:5160。
PORT=5160

# SQLite 数据库路径。Docker compose 已把 /app/data 挂载到宿主机 ./data。
DATABASE_PATH=/app/data/shadow7-mail.sqlite

# 前端静态文件目录。使用项目 Dockerfile 构建时保持默认即可。
WEB_DIST_PATH=/app/web/dist

# 附件存储目录。入站邮件附件会保存到这里，Docker compose 已通过 /app/data 持久化。
ATTACHMENT_DIR=/app/data/attachments

# 可选：服务器公网 IPv4。仅作为首次引导页预填值；用户在 UI 保存后以数据库配置为准。
PUBLIC_HOST=

# SMTP 入站服务监听地址。Docker 部署一般保持 0.0.0.0。
SMTP_INBOUND_HOST=0.0.0.0

# SMTP 入站收件端口。真实收件需要对公网开放 25/tcp，并让 MX 指向本机。
SMTP_INBOUND_PORT=25

# 是否启用内置 SMTP 入站收件服务。只使用 Web UI 或调试时可改为 false。
SMTP_INBOUND_ENABLED=true

# 单封入站邮件最大字节数。默认 10485760，即 10MB。
SMTP_INBOUND_MAX_BYTES=10485760

# 登录 Cookie 是否只允许 HTTPS 发送。HTTP 部署必须为 false；使用 HTTPS 后建议改为 true。
COOKIE_SECURE=false

# 后端日志级别。常用值：trace、debug、info、warn、error。生产默认 info。
LOG_LEVEL=info
